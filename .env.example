# Get a FREE key (no credit card required) at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here

# A random string used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-string

# Optional overrides
PORT=4000

# gemini-2.5-flash and gemini-2.5-flash-lite are on Google's free tier (as of 2026).
# gemini-2.0-flash was dropped from the free tier in a recent quota update — avoid it
# unless you have billing enabled.
GEMINI_MODEL=gemini-2.5-flash
